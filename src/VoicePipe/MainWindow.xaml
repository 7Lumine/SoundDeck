<Window x:Class="VoicePipe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SoundDeck"
        Width="1000"
        Height="680"
        MinWidth="1000"
        MinHeight="680"
        WindowStyle="None"
        ResizeMode="CanResize">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="52"
                        ResizeBorderThickness="6"
                        GlassFrameThickness="0"
                        CornerRadius="0"
                        UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>

  <Grid Background="{StaticResource WindowBackgroundBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="24"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource WindowBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="0,0,0,1">
      <Grid Margin="14,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
          <TextBlock Text="&#xE767;" Style="{StaticResource AccentIconTextBlock}" FontSize="20" Margin="0,0,10,0"/>
          <TextBlock Text="SoundDeck" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Column="1" Style="{StaticResource StatusPill}" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="TopStatusDot" Width="9" Height="9" Fill="{StaticResource AccentBlueBrush}" Margin="0,0,8,0"/>
            <TextBlock x:Name="TopStatusText" Text="Ready" Foreground="{StaticResource AccentBlueBrush}" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>

        <TextBlock Grid.Column="2"
                   x:Name="RouteSummaryText"
                   Text="ルート: Mic -> VC Output"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   Margin="16,0,18,0"
                   TextTrimming="CharacterEllipsis"/>

        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" Click="Settings_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE713;" Style="{StaticResource IconTextBlock}" FontSize="14" Margin="0,0,6,0"/>
              <TextBlock Text="設定"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButton}" Margin="0,0,10,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE897;" Style="{StaticResource IconTextBlock}" FontSize="14" Margin="0,0,6,0"/>
              <TextBlock Text="ヘルプ"/>
            </StackPanel>
          </Button>
          <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
            <Button Style="{StaticResource WindowControlButton}" Click="MinimizeWindow_Click" ToolTip="最小化" shell:WindowChrome.IsHitTestVisibleInChrome="True">
              <Viewbox Width="11" Height="11">
                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.4"
                      StrokeStartLineCap="Square"
                      StrokeEndLineCap="Square"
                      Data="M 1 8 L 11 8"/>
              </Viewbox>
            </Button>
            <Button x:Name="MaximizeRestoreButton" Style="{StaticResource WindowControlButton}" Click="MaximizeRestoreWindow_Click" ToolTip="最大化" shell:WindowChrome.IsHitTestVisibleInChrome="True">
              <Grid Width="13" Height="13">
                <Path x:Name="MaximizeIcon"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.2"
                      StrokeLineJoin="Miter"
                      Data="M 2 2 H 11 V 11 H 2 Z"/>
                <Path x:Name="RestoreIcon"
                      Visibility="Collapsed"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.2"
                      StrokeLineJoin="Miter"
                      Data="M 4 2 H 11 V 9 H 9 M 2 4 H 9 V 11 H 2 Z"/>
              </Grid>
            </Button>
            <Button Style="{StaticResource WindowCloseButton}" Click="CloseWindow_Click" ToolTip="閉じる" shell:WindowChrome.IsHitTestVisibleInChrome="True">
              <Viewbox Width="11" Height="11">
                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.4"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 2 2 L 10 10 M 10 2 L 2 10"/>
              </Viewbox>
            </Button>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="270"/>
        <ColumnDefinition Width="8"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="8"/>
        <ColumnDefinition Width="270"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource SectionPanel}">
        <StackPanel>
          <TextBlock Text="デバイス" Style="{StaticResource SectionTitle}"/>
          <Separator/>

          <TextBlock Text="マイク" Style="{StaticResource PanelTitle}" Margin="0,0,0,6"/>
          <ComboBox x:Name="InputDeviceCombo" DisplayMemberPath="Name" SelectionChanged="DeviceSelection_Changed" Margin="0,0,0,10"/>

          <TextBlock Text="VC出力" Style="{StaticResource PanelTitle}" Margin="0,0,0,6"/>
          <ComboBox x:Name="OutputDeviceCombo" DisplayMemberPath="Name" SelectionChanged="DeviceSelection_Changed" Margin="0,0,0,10"/>

          <Button Style="{StaticResource SecondaryButton}" Height="34" Click="RefreshDevices_Click" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock Text="&#xE72C;" Style="{StaticResource IconTextBlock}" FontSize="14" Margin="0,0,8,0"/>
              <TextBlock Text="デバイス更新"/>
            </StackPanel>
          </Button>

          <Separator/>
          <TextBlock Text="パイプコントロール" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>

          <Button Style="{StaticResource PrimaryButton}" Height="44" Click="StartPipe_Click" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock Text="&#xE768;" Style="{StaticResource IconTextBlock}" Foreground="White" FontSize="16" Margin="0,0,8,0"/>
              <TextBlock Text="送出開始" FontSize="15"/>
            </StackPanel>
          </Button>

          <Button Style="{StaticResource SecondaryButton}" Height="38" Click="StopPipe_Click" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock Text="&#xE71A;" Style="{StaticResource IconTextBlock}" FontSize="14" Margin="0,0,8,0"/>
              <TextBlock Text="送出停止"/>
            </StackPanel>
          </Button>

          <Border Style="{StaticResource ElevatedPanel}" Padding="12">
            <StackPanel>
              <TextBlock Text="現在のルート" Style="{StaticResource MutedText}" Margin="0,0,0,6"/>
              <TextBlock x:Name="CurrentRouteText"
                         Text="Mic -> VC Output"
                         Foreground="{StaticResource AccentBlueBrush}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         Margin="0,0,0,8"/>
              <Grid Height="38">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="38"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE720;" Style="{StaticResource IconTextBlock}" FontSize="22" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="···········" Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="&#xE8D6;" Style="{StaticResource IconTextBlock}" FontSize="21" HorizontalAlignment="Center"/>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource SectionPanel}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Soundboard" Style="{StaticResource SectionTitle}"/>
          <Separator Grid.Row="0" Margin="0,26,0,0"/>

          <Grid Grid.Row="1" Margin="0,14,0,8">
            <TextBox x:Name="SearchBox"
                     Text="クリップを検索..."
                     Foreground="{StaticResource MutedTextBrush}"
                     Padding="32,6,10,6"
                     MinHeight="36"
                     TextChanged="SearchBox_TextChanged"
                     GotKeyboardFocus="SearchBox_GotKeyboardFocus"
                     LostKeyboardFocus="SearchBox_LostKeyboardFocus"/>
            <TextBlock Text="&#xE721;" Style="{StaticResource IconTextBlock}" Foreground="{StaticResource MutedTextBrush}" FontSize="14" HorizontalAlignment="Left" Margin="10,0,0,0"/>
          </Grid>

          <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource ToolbarButton}" Click="AddMp3_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE710;" Style="{StaticResource IconTextBlock}" FontSize="14" Margin="0,0,6,0"/>
                <TextBlock Text="MP3追加"/>
              </StackPanel>
            </Button>
            <Button Grid.Column="2" Style="{StaticResource ToolbarButton}" Click="StopAllMp3_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE71A;" Style="{StaticResource IconTextBlock}" FontSize="14" Margin="0,0,6,0"/>
                <TextBlock Text="全停止"/>
              </StackPanel>
            </Button>
          </Grid>

          <Border Grid.Row="3"
                  x:Name="SelectedClipToolbar"
                  Background="{StaticResource CardBackgroundBrush}"
                  BorderBrush="{StaticResource BorderBrushDefault}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="9,7"
                  Margin="0,0,0,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="選択中:" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
              <TextBlock Grid.Column="1"
                         x:Name="SelectedClipNameText"
                         Text="クリップを選択すると編集できます"
                         Foreground="{StaticResource MutedTextBrush}"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis"/>
              <Button Grid.Column="3" x:Name="RenameClipButton" Style="{StaticResource SmallToolbarButton}" Click="RenameMp3_Click" Padding="8,5">
                <TextBlock Text="名前変更"/>
              </Button>
              <Button Grid.Column="5" x:Name="HotkeyClipButton" Style="{StaticResource SmallToolbarButton}" Click="SetHotkey_Click" Padding="8,5" ToolTip="キー設定">
                <TextBlock Text="キー"/>
              </Button>
              <Button Grid.Column="7" x:Name="RemoveClipButton" Style="{StaticResource SmallToolbarButton}" Click="RemoveMp3_Click" Padding="8,5">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE74D;" Style="{StaticResource DangerIconTextBlock}" FontSize="13" Margin="0,0,5,0"/>
                  <TextBlock Text="削除"/>
                </StackPanel>
              </Button>
              <CheckBox Grid.Column="9" x:Name="LoopCheck" Content="ループ" VerticalAlignment="Center" Checked="ClipLoop_Changed" Unchecked="ClipLoop_Changed"/>
            </Grid>
          </Border>

          <Border Grid.Row="4" Style="{StaticResource ElevatedPanel}" Padding="10" Margin="0,0,0,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="再生中" Style="{StaticResource PanelTitle}"/>
                <TextBlock Text="複数MP3を同時再生できます" Style="{StaticResource MutedText}" Margin="0,2,0,0"/>
              </StackPanel>
              <ItemsControl Grid.Column="1" x:Name="NowPlayingItems" ItemsSource="{Binding ActiveClips}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrushDefault}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,5"
                            Margin="0,0,6,6">
                      <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBlueBrush}" Margin="0,0,7,0"/>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding DurationText}" Style="{StaticResource MutedText}"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Grid.Column="2" x:Name="ActiveClipsText" Text="0 件再生中" Style="{StaticResource MutedText}" VerticalAlignment="Top"/>
            </Grid>
          </Border>

          <Grid Grid.Row="5">
            <ScrollViewer x:Name="ClipScrollViewer"
                          Style="{StaticResource DarkScrollViewerStyle}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          PreviewMouseWheel="ClipScrollViewer_PreviewMouseWheel">
              <ScrollViewer.Resources>
                <DataTemplate x:Key="ClipCardTemplate">
                    <Border Width="182" Height="158" Style="{StaticResource ClipCard}" MouseLeftButtonDown="ClipCard_MouseLeftButtonDown">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="30"/>
                          <RowDefinition Height="20"/>
                          <RowDefinition Height="38"/>
                          <RowDefinition Height="26"/>
                          <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="&#xE767;" Style="{StaticResource AccentIconTextBlock}" FontSize="16" Margin="0,0,8,0"/>
                          <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                            <Button Style="{StaticResource PinButton}" Click="PinClip_Click">
                              <Viewbox Width="14" Height="14">
                                <Path Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="M5 1 H11 V3 L10 4 V8 L13 11 V12 H9 V15 L8 16 L7 15 V12 H3 V11 L6 8 V4 L5 3 Z"/>
                              </Viewbox>
                            </Button>
                            <Ellipse Width="8" Height="8" Margin="5,0,0,0" VerticalAlignment="Center">
                              <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                  <Setter Property="Fill" Value="{StaticResource MutedTextBrush}"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                      <Setter Property="Fill" Value="{StaticResource AccentBlueBrush}"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </Ellipse.Style>
                            </Ellipse>
                          </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" VerticalAlignment="Center">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0"
                                     Text="{Binding StatusTimeText}"
                                     Style="{StaticResource MutedText}"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center"/>
                          <Border Grid.Column="1"
                                  Style="{StaticResource HotkeyBadge}"
                                  Margin="6,0,0,0"
                                  ToolTip="{Binding HotkeyDisplayText}">
                            <TextBlock Text="{Binding HotkeyText}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="72"/>
                          </Border>
                        </Grid>

                        <Grid Grid.Row="2" HorizontalAlignment="Center">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="36"/>
                          </Grid.ColumnDefinitions>
                          <Button Grid.Column="0" Style="{StaticResource IconButton}" Click="PlayClip_Click" ToolTip="再生">
                            <Viewbox Width="13" Height="13">
                              <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="M 0 0 L 0 12 L 10 6 Z"/>
                            </Viewbox>
                          </Button>
                          <Button Grid.Column="2" Style="{StaticResource IconButton}" Click="StopClip_Click" ToolTip="停止">
                            <Viewbox Width="11" Height="11">
                              <Rectangle Width="10" Height="10" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Viewbox>
                          </Button>
                        </Grid>

                        <Slider Grid.Row="3"
                                Style="{StaticResource SeekSlider}"
                                Minimum="0"
                                Maximum="{Binding DurationSeconds}"
                                Value="{Binding PositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PreviewMouseDown="SeekSlider_PreviewMouseDown"
                                PreviewMouseUp="SeekSlider_PreviewMouseUp"/>

                        <DockPanel Grid.Row="4" VerticalAlignment="Bottom">
                          <TextBlock Text="&#xE767;" Style="{StaticResource IconTextBlock}" Foreground="{StaticResource MutedTextBrush}" FontSize="14" Margin="0,0,6,0"/>
                          <TextBlock Text="{Binding VolumeText}" Style="{StaticResource MutedText}" DockPanel.Dock="Right" Margin="6,0,0,0"/>
                          <Slider Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ValueChanged="ClipVolume_Changed"/>
                        </DockPanel>
                      </Grid>
                    </Border>
                </DataTemplate>
              </ScrollViewer.Resources>
              <ItemsControl x:Name="ClipList" ItemsSource="{Binding DisplayedClips}" ItemTemplate="{StaticResource ClipCardTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </ScrollViewer>

            <WrapPanel x:Name="MockClipGrid">
              <Border Width="182" Height="158" Style="{StaticResource ClipCard}" Opacity="0.64">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="&#xE767;" Style="{StaticResource AccentIconTextBlock}" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Airhorn" FontWeight="SemiBold"/>
                  </StackPanel>
                  <TextBlock Grid.Row="1" Text="停止中" Style="{StaticResource MutedText}"/>
                  <Grid Grid.Row="2" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="36"/>
                      <ColumnDefinition Width="8"/>
                      <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource IconButton}" IsEnabled="False">
                      <Viewbox Width="13" Height="13">
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="M 0 0 L 0 12 L 10 6 Z"/>
                      </Viewbox>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" IsEnabled="False">
                      <Viewbox Width="11" Height="11">
                        <Rectangle Width="10" Height="10" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                      </Viewbox>
                    </Button>
                  </Grid>
                  <Slider Grid.Row="3" Style="{StaticResource SeekSlider}" Minimum="0" Maximum="5" Value="0" IsEnabled="False"/>
                  <Slider Grid.Row="4" Minimum="0" Maximum="100" Value="62" IsEnabled="False"/>
                </Grid>
              </Border>
              <Border Width="182" Height="158" Style="{StaticResource ClipCard}" Opacity="0.64">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="&#xE767;" Style="{StaticResource AccentIconTextBlock}" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Laugh" FontWeight="SemiBold"/>
                  </StackPanel>
                  <TextBlock Grid.Row="1" Text="停止中" Style="{StaticResource MutedText}"/>
                  <Grid Grid.Row="2" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="36"/>
                      <ColumnDefinition Width="8"/>
                      <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource IconButton}" IsEnabled="False">
                      <Viewbox Width="13" Height="13">
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="M 0 0 L 0 12 L 10 6 Z"/>
                      </Viewbox>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" IsEnabled="False">
                      <Viewbox Width="11" Height="11">
                        <Rectangle Width="10" Height="10" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                      </Viewbox>
                    </Button>
                  </Grid>
                  <Slider Grid.Row="3" Style="{StaticResource SeekSlider}" Minimum="0" Maximum="8" Value="0" IsEnabled="False"/>
                  <Slider Grid.Row="4" Minimum="0" Maximum="100" Value="74" IsEnabled="False"/>
                </Grid>
              </Border>
              <Border Width="182" Height="158" Style="{StaticResource ClipCard}" Opacity="0.64">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="&#xE767;" Style="{StaticResource AccentIconTextBlock}" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Drum Fill" FontWeight="SemiBold"/>
                  </StackPanel>
                  <TextBlock Grid.Row="1" Text="停止中" Style="{StaticResource MutedText}"/>
                  <Grid Grid.Row="2" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="36"/>
                      <ColumnDefinition Width="8"/>
                      <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource IconButton}" IsEnabled="False">
                      <Viewbox Width="13" Height="13">
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="M 0 0 L 0 12 L 10 6 Z"/>
                      </Viewbox>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" IsEnabled="False">
                      <Viewbox Width="11" Height="11">
                        <Rectangle Width="10" Height="10" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                      </Viewbox>
                    </Button>
                  </Grid>
                  <Slider Grid.Row="3" Style="{StaticResource SeekSlider}" Minimum="0" Maximum="3" Value="0" IsEnabled="False"/>
                  <Slider Grid.Row="4" Minimum="0" Maximum="100" Value="56" IsEnabled="False"/>
                </Grid>
              </Border>
            </WrapPanel>
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Column="4" Style="{StaticResource SectionPanel}">
        <StackPanel>
          <TextBlock Text="ミキサー" Style="{StaticResource SectionTitle}"/>
          <Separator/>

          <TextBlock Text="マイク音量" Style="{StaticResource PanelTitle}" Margin="0,0,0,6"/>
          <DockPanel Margin="0,0,0,12">
            <Border DockPanel.Dock="Right" Style="{StaticResource ElevatedPanel}" Padding="9,5" Margin="8,0,0,0">
              <TextBlock x:Name="MicVolumeText" Text="100%" Width="36" TextAlignment="Center"/>
            </Border>
            <Slider x:Name="MicVolumeSlider" Minimum="0" Maximum="100" Value="100" ValueChanged="Volume_Changed"/>
          </DockPanel>

          <TextBlock Text="MP3音量" Style="{StaticResource PanelTitle}" Margin="0,0,0,6"/>
          <DockPanel Margin="0,0,0,12">
            <Border DockPanel.Dock="Right" Style="{StaticResource ElevatedPanel}" Padding="9,5" Margin="8,0,0,0">
              <TextBlock x:Name="Mp3VolumeText" Text="75%" Width="36" TextAlignment="Center"/>
            </Border>
            <Slider x:Name="Mp3VolumeSlider" Minimum="0" Maximum="100" Value="75" ValueChanged="Volume_Changed"/>
          </DockPanel>

          <Separator/>
          <CheckBox x:Name="MuteMicCheck" Content="マイクミュート" Checked="AudioOption_Changed" Unchecked="AudioOption_Changed" Margin="0,0,0,10"/>
          <CheckBox x:Name="DuckingCheck" Content="MP3再生中はマイクを下げる" Checked="AudioOption_Changed" Unchecked="AudioOption_Changed" Margin="0,0,0,10"/>

          <DockPanel Margin="0,0,0,12">
            <TextBlock Text="下げる量" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
            <ComboBox x:Name="DuckingAmountCombo"
                      DockPanel.Dock="Right"
                      Width="92"
                      SelectionChanged="DuckingAmount_Changed">
              <ComboBoxItem Content="-6 dB" Tag="-6"/>
              <ComboBoxItem Content="-9 dB" Tag="-9"/>
              <ComboBoxItem Content="-12 dB" Tag="-12"/>
              <ComboBoxItem Content="-18 dB" Tag="-18"/>
              <ComboBoxItem Content="-24 dB" Tag="-24"/>
            </ComboBox>
          </DockPanel>

          <Separator/>
          <Grid Margin="0,0,0,7">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="&#xE7F6;" Style="{StaticResource AccentIconTextBlock}" FontSize="15" Margin="0,0,7,0"/>
              <TextBlock Text="モニター" Style="{StaticResource SectionTitle}"/>
            </StackPanel>
            <UniformGrid Grid.Column="1" Columns="3" Margin="10,0,0,0">
              <RadioButton x:Name="MonitorModeOff"
                           Content="Off"
                           Tag="None"
                           GroupName="MonitorMode"
                           Style="{StaticResource SegmentButton}"
                           ToolTip="モニターしない"
                           Checked="MonitorModeRadio_Checked"
                           Margin="0,0,4,0"/>
              <RadioButton x:Name="MonitorModeMp3"
                           Content="MP3"
                           Tag="Mp3Only"
                           GroupName="MonitorMode"
                           Style="{StaticResource SegmentButton}"
                           ToolTip="MP3音声だけを聞く"
                           Checked="MonitorModeRadio_Checked"
                           Margin="0,0,4,0"/>
              <RadioButton x:Name="MonitorModeMixed"
                           Content="Mix"
                           Tag="Mixed"
                           GroupName="MonitorMode"
                           Style="{StaticResource SegmentButton}"
                           ToolTip="マイクとMP3のミックスを聞く"
                           Checked="MonitorModeRadio_Checked"/>
            </UniformGrid>
          </Grid>
          <ComboBox x:Name="MonitorOutputCombo"
                    DisplayMemberPath="Name"
                    Visibility="Collapsed"
                    SelectionChanged="Monitor_Changed"/>
          <DockPanel Margin="0,0,0,7">
            <Border DockPanel.Dock="Right" Style="{StaticResource ElevatedPanel}" Padding="8,4" Margin="8,0,0,0">
              <TextBlock x:Name="MonitorVolumeText" Text="50%" Width="34" TextAlignment="Center"/>
            </Border>
            <Slider x:Name="MonitorVolumeSlider" Minimum="0" Maximum="100" Value="50" ValueChanged="MonitorVolume_Changed"/>
          </DockPanel>
          <DockPanel Margin="0,0,0,4">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource SmallToolbarButton}"
                    Content="変更"
                    Width="54"
                    Click="ChangeMonitorOutput_Click"/>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="出力:" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,5,0"/>
              <TextBlock x:Name="MonitorOutputText"
                         Text="既定の再生デバイス"
                         Style="{StaticResource MutedText}"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis"
                         Width="142"/>
            </StackPanel>
          </DockPanel>
          <TextBlock x:Name="MonitorWarningText"
                     Text="モニター出力とVC出力が同じです"
                     Foreground="{StaticResource WarningBrush}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Visibility="Collapsed"
                     Margin="0,0,0,2"/>

          <Separator/>
          <TextBlock Text="レベルメーター" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
          <Grid Height="120" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
              <TextBlock Text="Mic" TextAlignment="Center" FontSize="12" Margin="0,0,0,6"/>
              <ItemsControl ItemsSource="{Binding MicSegments}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource MeterSegment}" Background="{Binding Fill}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
              <TextBlock Text="Clips" TextAlignment="Center" FontSize="12" Margin="0,0,0,6"/>
              <ItemsControl ItemsSource="{Binding ClipsSegments}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource MeterSegment}" Background="{Binding Fill}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
              <TextBlock Text="Output" TextAlignment="Center" FontSize="12" Margin="0,0,0,6"/>
              <ItemsControl ItemsSource="{Binding OutputSegments}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource MeterSegment}" Background="{Binding Fill}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="{StaticResource WindowBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="0,1,0,0">
      <Grid Margin="14,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" x:Name="StatusText" Text="デバイスとボリューム設定を保存しています" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,18,0" TextTrimming="CharacterEllipsis"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="サンプルレート: 48 kHz" Style="{StaticResource MutedText}"/>
          <TextBlock Text="|" Style="{StaticResource MutedText}" Margin="12,0"/>
          <TextBlock Text="バージョン: 0.1.1" Style="{StaticResource MutedText}"/>
          <TextBlock Text="|" Style="{StaticResource MutedText}" Margin="12,0"/>
          <TextBlock Text="フィードバック" Style="{StaticResource MutedText}"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
