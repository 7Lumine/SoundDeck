<Window x:Class="VoicePipe.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="設定"
        Width="430"
        MinHeight="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="42"
                        ResizeBorderThickness="0"
                        GlassFrameThickness="0"
                        CornerRadius="0"
                        UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>

  <Border Background="{StaticResource PanelBackgroundBrush}"
          BorderBrush="{StaticResource BorderBrushDefault}"
          BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="42"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="設定"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="18,0,0,0"/>
        <Button Grid.Column="1"
                Style="{StaticResource WindowCloseButton}"
                Click="CloseDialog_Click"
                ToolTip="閉じる"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <Viewbox Width="11" Height="11">
            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.4"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Data="M 2 2 L 10 10 M 10 2 L 2 10"/>
          </Viewbox>
        </Button>
      </Grid>

      <Grid Grid.Row="1" Margin="20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ElevatedPanel}"
                Padding="14"
                Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="レベルメーター" Style="{StaticResource PanelTitle}" Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="92"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="54"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="マイク" VerticalAlignment="Center"/>
              <Slider Grid.Column="1"
                      x:Name="MicMeterSlider"
                      Minimum="0.5"
                      Maximum="4"
                      TickFrequency="0.1"
                      ValueChanged="MeterSlider_Changed"/>
              <TextBlock Grid.Column="2"
                         x:Name="MicMeterValueText"
                         TextAlignment="Right"
                         Style="{StaticResource MutedText}"
                         VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="92"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="54"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="クリップ" VerticalAlignment="Center"/>
              <Slider Grid.Column="1"
                      x:Name="ClipsMeterSlider"
                      Minimum="0.5"
                      Maximum="4"
                      TickFrequency="0.1"
                      ValueChanged="MeterSlider_Changed"/>
              <TextBlock Grid.Column="2"
                         x:Name="ClipsMeterValueText"
                         TextAlignment="Right"
                         Style="{StaticResource MutedText}"
                         VerticalAlignment="Center"/>
            </Grid>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="92"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="54"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="出力" VerticalAlignment="Center"/>
              <Slider Grid.Column="1"
                      x:Name="OutputMeterSlider"
                      Minimum="0.5"
                      Maximum="4"
                      TickFrequency="0.1"
                      ValueChanged="MeterSlider_Changed"/>
              <TextBlock Grid.Column="2"
                         x:Name="OutputMeterValueText"
                         TextAlignment="Right"
                         Style="{StaticResource MutedText}"
                         VerticalAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ElevatedPanel}"
                Padding="14"
                Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="VC出力" Style="{StaticResource PanelTitle}" Margin="0,0,0,10"/>
            <DockPanel>
              <TextBlock Text="レイテンシ"
                         VerticalAlignment="Center"/>
              <ComboBox x:Name="VcLatencyCombo"
                        DockPanel.Dock="Right"
                        Width="116">
                <ComboBoxItem Content="50 ms" Tag="50"/>
                <ComboBoxItem Content="80 ms" Tag="80"/>
                <ComboBoxItem Content="100 ms" Tag="100"/>
                <ComboBoxItem Content="150 ms" Tag="150"/>
                <ComboBoxItem Content="200 ms" Tag="200"/>
                <ComboBoxItem Content="300 ms" Tag="300"/>
              </ComboBox>
            </DockPanel>
            <CheckBox x:Name="LowLatencyModeCheck"
                      Content="低遅延モード"
                      Margin="0,12,0,0"
                      Checked="LowLatencyMode_Changed"
                      Unchecked="LowLatencyMode_Changed"
                      ToolTip="マイク入力バッファを短くします。環境によってはプツプツしやすくなる場合があります。"/>
            <TextBlock Text="不安定な場合はOFFにして、レイテンシを200msまたは300msへ戻してください。"
                       Style="{StaticResource MutedText}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
          </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource ElevatedPanel}"
                Padding="14"
                Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="診断" Style="{StaticResource PanelTitle}" Margin="0,0,0,10"/>
            <UniformGrid Columns="2">
              <Button Content="テストトーン"
                      Style="{StaticResource SecondaryButton}"
                      Height="34"
                      Margin="0,0,6,0"
                      Click="TestTone_Click"/>
              <Button Content="無音ストリーム"
                      Style="{StaticResource SecondaryButton}"
                      Height="34"
                      Margin="6,0,0,0"
                      Click="SilenceTest_Click"/>
            </UniformGrid>
          </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="メーター感度は表示だけに反映され、実際の音量やVC出力には影響しません。VC出力レイテンシは次回の送出開始から反映されます。"
                   Style="{StaticResource MutedText}"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
          <Button Content="既定値"
                  Style="{StaticResource SecondaryButton}"
                  Width="86"
                  Height="36"
                  MinHeight="36"
                  Padding="10,4"
                  Margin="0,0,8,0"
                  Click="Reset_Click"/>
          <Button Content="キャンセル"
                  Style="{StaticResource SecondaryButton}"
                  Width="96"
                  Height="36"
                  MinHeight="36"
                  Padding="10,4"
                  Margin="0,0,8,0"
                  IsCancel="True"
                  Click="Cancel_Click"/>
          <Button Content="保存"
                  Style="{StaticResource PrimaryButton}"
                  Width="82"
                  Height="36"
                  MinHeight="36"
                  Padding="10,4"
                  FontSize="13"
                  IsDefault="True"
                  Click="Ok_Click"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
